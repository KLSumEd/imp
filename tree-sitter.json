{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "imp",
      "camelcase": "IMP",
      "title": "IMP",
      "scope": "source.imp",
      "file-types": [
        "act"
      ],
      "injection-regex": "^imp$",
      "class-name": "TreeSitterImp"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL 2.0",
    "description": "The Immortal Model Parser. Designed to parse the Archeotech (*.act) markup language, and the Bane (*.bane) Scripting Language",
    "authors": [
      {
        "name": "KLSumEd",
        "email": "kaisumed@gmail.com",
        "url": "https://github.com/KLSumEd"
      }
    ],
    "links": {
      "repository": "https://github.com/KLSumEd/imp",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}