{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "bsp",
      "camelcase": "BSP",
      "title": "BSP",
      "scope": "source.bsp",
      "file-types": [
        "bsc",
        "bs",
        "bane",
        "bn"
      ],
      "injection-regex": "^bsp$",
      "class-name": "TreeSitterBsp"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "GPL 2.0",
    "description": "The Bane Script Parser. Designed to parse the Bane (*.bane) Scripting Language.",
    "authors": [
      {
        "name": "Kai Sumner-Edwards",
        "email": "kaisumed@gmail.com",
        "url": "https://github.com/KLSumEd"
      }
    ],
    "links": {
      "repository": "https://github.com/KLSumEd/imp",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}